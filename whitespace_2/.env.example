# ws2 environment variables
#
# Copy this file to `whitespace_2/.env` and fill in real values.
# `.env` is gitignored (whitespace_2/.gitignore line 19) — never committed.
#
# Scripts that need these keys call `load_dotenv()` at startup
# (via `from dotenv import load_dotenv`); python-dotenv is in
# `pyproject.toml` dependencies so it's available after
# `uv sync --extra dev`.
#
# To rotate a key: edit `.env`, no code change needed.
# To check what's loaded: `uv run python -c "import os; from dotenv import load_dotenv; load_dotenv(); print({k: '***' if v else '(unset)' for k, v in [(k, os.environ.get(k)) for k in ['NAMSOR_API_KEY', 'GENDERIZE_API_KEY', 'SEMANTIC_SCHOLAR_API_KEY']]})"`

# ---- Demographic inference (Phase 0.1 Check 3 + Phase 0.2 Stage 1) ----

# NamSor: name → gender + nationality + ethnicity inference.
# Tier locked Phase 0.2 for low-confidence escalation subset.
# Sign up at https://namsor.com/. Keep within $50-500 plan budget.
NAMSOR_API_KEY=

# Genderize.io: name → gender.
# Free-with-key tier is 2500/mo. Paid tiers needed for production-scale
# Stage 1 (~450K unique names; see phase-0.2-plan.md §"Stage 1 prereqs").
# Sign up at https://genderize.io/.
GENDERIZE_API_KEY=

# ---- Optional: bibliometric data sources ----

# Semantic Scholar (S2AG): used in Check 1e abstract-coverage cross-check.
# Anonymous access works for low rate; key only needed if hitting limits.
# Sign up at https://www.semanticscholar.org/product/api.
SEMANTIC_SCHOLAR_API_KEY=
